{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            // 必须和 tasks.json 里的输出路径完全一致
            "program": "/home/albert/cv-course/myproj/zuoye2/build/main_exec", 
            "args": [],
            "stopAtEntry": false,
            // 程序运行时的“家”目录。图片放在这里，代码里就能直接写文件名读取
            "cwd": "/home/albert/cv-course/myproj/zuoye2",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // 必须和 tasks.json 里的 label 名字一字不差
            "preLaunchTask": "C/C++: g++ 生成活动文件", 
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}